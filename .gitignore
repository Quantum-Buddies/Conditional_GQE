# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# PyTorch checkpoints (large binary files)
*.pt
*.pth
*.pth.tar

# Temporary SCF files
*.chk
*.log
*.tmp

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Environment files (keep yml templates, ignore lock files)
*.lock

# Large result artifacts (keep JSON summaries, ignore binaries)
results/**/*.png
results/**/*.pdf
results/**/*_history.json

# Keep specific plots for README
!results/plots/benchmark_*.png
!results/plots_phase3/*.png

# QBraid skill artifacts
qbraid_skill/*.tar.gz

# Proposal PDFs (generated, not source)
proposals/*.pdf

# HPC job logs
jobs/*.out
jobs/*.err
results/logs/
slurm-*.out
slurm-*.err

# Downloaded papers (not our content)
*.pdf
!proposals/cover_page_assets/**/*.png
!results/plots/benchmark_*.png
!results/plots_phase3/*.png

# Scaling benchmark large outputs
results/scaling_benchmark/**/*.npy
results/scaling_benchmark/**/*.pt

# Large Hamiltonian JSON files (>50MB, use Git LFS or exclude)
results/data/hamiltonians_40plus.json/
results/data/hamiltonians_scaling.json/

# HuggingFace upload staging
huggingface_upload/

# RL energy cache runtime files (commit .sqlite only, not WAL sidecars)
results/train/rl_energy_cache.sqlite-shm
results/train/rl_energy_cache.sqlite-wal
results/train/rl_energy_cache.sqlite.bak-*

# Benchmark scratch files
benchmark_mps.py
benchmark_mps_deep.py
benchmark_mps_full.py
benchmark_mps_huge.py
benchmark_sv.py

# Plan files
scripts/plan_qbraid_experiments.py
